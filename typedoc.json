{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "packages/formbar-core/src/index.ts",
    "packages/formbar-react/src/index.ts",
    "packages/formbar-from-schema/src/index.ts"
  ],
  "out": "docs/api/generated",
  "plugin": ["typedoc-plugin-markdown"],
  "readme": "none",
  "name": "Formbar API Reference",
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeExternals": true,
  "tsconfig": "./tsconfig.typedoc.json",
  "sort": ["source-order"],
  "categorizeByGroup": true,
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  }
}
