{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@scheman/core": ["../../packages/scheman-core/src/index.ts"],
      "@ghost-shell/table-from-schema": ["../../packages/table-from-schema/src/index.ts"],
      "@ghost-shell/entity-table": ["../../packages/entity-table/src/index.ts"],
      "@ghost-shell/data-table": ["../../packages/data-table/src/index.ts"],
      "@ghost-shell/ui": ["../../packages/ui/src/index.ts"],
      "@ghost-shell/contracts": ["../../packages/plugin-contracts/src/index.ts"],
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
