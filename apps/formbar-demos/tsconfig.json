{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@formbar/core": ["../../packages/formbar-core/src/index.ts"],
      "@ghost-shell/schema-core": ["../../packages/schema-core/src/index.ts"],
      "@formbar/from-schema": ["../../packages/formbar-from-schema/src/index.ts"],
      "@formbar/react": ["../../packages/formbar-react/src/index.ts"],
      "@ghost-shell/ui": ["../../packages/ui/src/index.ts"],
      "@ghost-shell/contracts": ["../../packages/plugin-contracts/src/index.ts"],
      "@ghost-shell/predicate": ["../../packages/predicate/src/index.ts"],
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
