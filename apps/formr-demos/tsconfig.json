{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@ghost-shell/formr-core": ["../../packages/formr-core/src/index.ts"],
      "@scheman/core": ["../../packages/scheman-core/src/index.ts"],
      "@ghost-shell/formr-from-schema": ["../../packages/formr-from-schema/src/index.ts"],
      "@ghost-shell/formr-react": ["../../packages/formr-react/src/index.ts"],
      "@ghost-shell/ui": ["../../packages/ui/src/index.ts"],
      "@ghost-shell/contracts": ["../../packages/plugin-contracts/src/index.ts"],
      "@ghost-shell/predicate": ["../../packages/predicate/src/index.ts"],
      "@/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"]
}
