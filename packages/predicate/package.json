      "types": "./dist/collection.d.ts",
      "import": "./dist/collection.js",
      "require": "./dist/collection.cjs"
    },
    "./filter": {
      "types": "./dist/filter.d.ts",
      "import": "./dist/filter.js",
      "require": "./dist/filter.cjs"
    },
    "./compile": {
      "types": "./dist/compile.d.ts",
      "import": "./dist/compile.js",
      "require": "./dist/compile.cjs"
    },
    "./evaluate": {
      "types": "./dist/evaluate.d.ts",
      "import": "./dist/evaluate.js",
      "require": "./dist/evaluate.cjs"
    },
    "./trace": {
      "types": "./dist/trace.d.ts",
      "import": "./dist/trace.js",
      "require": "./dist/trace.cjs"
    },
    "./operators": {
      "types": "./dist/operators.d.ts",
      "import": "./dist/operators.js",
      "require": "./dist/operators.cjs"
    },
    "./ast": {
      "types": "./dist/ast.d.ts",
      "import": "./dist/ast.js",
