{
  "name": "@ghost-shell/entity-table",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": null
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:dist": "tsup"
  },
  "dependencies": {
    "@ghost-shell/contracts": "workspace:*",
    "@ghost-shell/data-table": "workspace:*",
    "@scheman/core": "workspace:*",
    "@ghost-shell/table-from-schema": "workspace:*",
    "@ghost-shell/ui": "workspace:*",
    "lucide-react": "^0.475.0"
  },
  "peerDependencies": {
    "@chenglou/pretext": ">=0.0.6",
    "@tanstack/react-table": "^8.21.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.0"
  },
  "peerDependenciesMeta": {
    "@chenglou/pretext": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@chenglou/pretext": "0.0.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"
  }
}
