{
  "extends": "../sentinel/tsconfig.sentinel-base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "resolveJsonModule": true,
    "exactOptionalPropertyTypes": false,
    "isolatedModules": true,
    "types": ["@types/bun"],
    "paths": {
      "@ghost/sentinel": ["../sentinel/src/index.ts"],
      "@ghost-shell/predicate": ["../predicate/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
