{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "composite": true
  },
  "include": ["src"],
  "exclude": ["src/**/__tests__", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "references": [{ "path": "../formbar-core" }, { "path": "../formbar-from-schema" }]
}
