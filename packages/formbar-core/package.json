{
  "name": "@formbar/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./path": {
      "types": {
        "import": "./dist/path.d.ts",
        "require": "./dist/path.d.cts"
      },
      "import": "./dist/path.js",
      "require": "./dist/path.cjs"
    },
    "./transforms": {
      "types": {
        "import": "./dist/transforms.d.ts",
        "require": "./dist/transforms.d.cts"
      },
      "import": "./dist/transforms.js",
      "require": "./dist/transforms.cjs"
    },
    "./validation": {
      "types": {
        "import": "./dist/validation.d.ts",
        "require": "./dist/validation.d.cts"
      },
      "import": "./dist/validation.js",
      "require": "./dist/validation.cjs"
    },
    "./*": null
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "dependencies": {
    "kuery": "file:../../../../../kuery",
    "@ghost-shell/arbiter": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bun test",
    "build:dist": "tsup"
  }
}
