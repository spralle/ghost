{
  "name": "ghost.settings-panel",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "ghost": {
    "displayName": "Settings Panel",
    "contributes": {
      "parts": [
        {
          "id": "ghost.shell.settings",
          "title": "Settings"
        },
        {
          "id": "ghost.shell.settings.diagnostics",
          "title": "Configuration Diagnostics"
        }
      ]
    },
    "dependsOn": {
      "services": [
        {
          "id": "ghost.configuration.Service",
          "versionRange": "^1.0.0",
          "optional": true
        }
      ],
      "plugins": [
        {
          "pluginId": "ghost.ui",
          "versionRange": "^1.0.0"
        },
        {
          "pluginId": "ghost.shadcn.theme-bridge",
          "versionRange": "^1.0.0"
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite"
  },
  "dependencies": {
    "@ghost-shell/contracts": "file:../../packages/plugin-contracts",
    "@ghost-shell/react": "file:../../packages/react",
    "@scheman/core": "workspace:*",
    "@ghost-shell/formr-react": "workspace:*",
    "@ghost-shell/formr-from-schema": "workspace:*",
    "@ghost-shell/formr-core": "workspace:*",
    "@ghost-shell/weaver-formr-bridge": "workspace:*",
    "@ghost-shell/ui": "file:../../packages/ui",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.8.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.19"
  }
}
